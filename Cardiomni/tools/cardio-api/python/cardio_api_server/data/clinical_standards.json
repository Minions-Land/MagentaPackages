  "timi_flow": {
    "description": "TIMI Flow Grade (Thrombolysis In Myocardial Infarction)",
    "grades": {
      "0": "No perfusion: no antegrade flow beyond occlusion",
      "1": "Penetration without perfusion: contrast passes beyond obstruction but fails to opacify distal bed",
      "2": "Partial perfusion: contrast opacifies distal bed but clearance is slower than normal",
      "3": "Complete perfusion: normal flow with complete filling and clearance"
    }
  },
  "timi_thrombus": {
    "description": "TIMI Thrombus Grade",
    "grades": {
      "0": "No angiographic thrombus",
      "1": "Possible thrombus: reduced contrast density, haziness, irregular lesion contour",
      "2": "Small thrombus: definite thrombus, greatest dimension ≤1/2 vessel diameter",
      "3": "Moderate thrombus: definite thrombus >1/2 but <2 vessel diameters",
      "4": "Large thrombus: definite thrombus ≥2 vessel diameters",
      "5": "Total occlusion: complete thrombotic occlusion"
    }
  },
  "rentrop_collaterals": {
    "description": "Rentrop Collateral Grading System",
    "grades": {
      "0": "No visible collateral circulation",
      "1": "Filling of side branches via collaterals without visualization of epicardial artery",
      "2": "Partial filling of epicardial artery via collaterals",
      "3": "Complete filling of epicardial artery via collaterals"
    }
  },
